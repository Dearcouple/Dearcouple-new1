          <label class="rsvp-label">Which events will you attend?</label>
          <div class="rsvp-options" id="rsvp-events">
            <label class="rsvp-option">
              <input type="checkbox" value="Traditional Wedding (Wed 6th August)" /> Traditional Wedding <span style="color:var(--gray);font-size:0.8em">· Wed 6th August</span>
            </label>
