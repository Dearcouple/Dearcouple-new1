  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,300;1,9..144,400;1,9..144,500&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=Italianno&display=swap" rel="stylesheet" />
  <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet" />

  <style>
    /* ══════════════════════════════════════════
       DESIGN TOKENS
    ══════════════════════════════════════════ */
    :root {
      --warm-white:     #FFFDF9;
      --cream:          #FDF8F0;
      --champagne:      #E8D5A3;
      --champagne-lt:   #F5EACA;
      --champagne-dk:   #C4A86A;
      --orange:         #C85C38;
      --orange-lt:      #E07A55;
      --orange-dk:      #9A3E22;
      --brown:          #5C2E14;
      --brown-lt:       #8B4E2A;
      --brown-dk:       #2D1408;
      --charcoal:       #2D1A0E;
      --gray:           #7A5A4A;
      --light-gray:     #EFE0D5;
      --white:          #FFFFFF;

      --font-display:   'Fraunces', Georgia, serif;
      --font-serif:     'Cormorant Garamond', Georgia, serif;
      --font-sans:      'DM Sans', sans-serif;

      --radius:         999px;
      --shadow:         0 4px 24px rgba(90,40,10,0.08);
      --shadow-lg:      0 10px 48px rgba(90,40,10,0.16);
      --ease:           cubic-bezier(0.16, 1, 0.3, 1);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      background: var(--warm-white);
      color: var(--charcoal);
      font-family: var(--font-sans);
      font-weight: 300;
      line-height: 1.7;
      overflow-x: hidden;
    }
    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }
    ::-webkit-scrollbar { width: 3px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--champagne-dk); border-radius: 2px; }

    /* ══════════════════════════════════════════
       UTILITY
    ══════════════════════════════════════════ */
    .section-label {
      font-family: var(--font-sans);
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 0.75rem;
    }
    .section-title {
      font-family: var(--font-serif);
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 400;
      color: var(--charcoal);
      line-height: 1.15;
    }
    .section-title em { font-style: italic; color: var(--orange-dk); }
    .divider {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin: 1.5rem 0;
    }
    .divider::before, .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, transparent, var(--champagne-dk), transparent);
    }
    .divider span { color: var(--champagne-dk); font-size: 0.75rem; }

    /* ══════════════════════════════════════════
       FLOATING NAV
    ══════════════════════════════════════════ */
    .nav-wrapper {
      position: fixed;
      top: 1.2rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 999;
      transition: all 0.4s var(--ease);
    }
    .nav-pill {
      display: flex;
      align-items: center;
      gap: 0.1rem;
      background: rgba(255,255,255,0.1);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.22);
      border-radius: 100px;
      padding: 0.45rem 0.8rem;
      box-shadow: 0 4px 30px rgba(0,0,0,0.14);
      transition: background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
    }
    .nav-wrapper.scrolled .nav-pill {
      background: rgba(253,248,240,0.94);
      border-color: rgba(200,92,56,0.12);
      box-shadow: 0 4px 32px rgba(90,40,10,0.1);
    }
    .nav-link {
      font-family: var(--font-sans);
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.88);
      padding: 0.42rem 0.8rem;
      border-radius: 100px;
      transition: color 0.25s, background 0.25s;
      white-space: nowrap;
    }
    .nav-wrapper.scrolled .nav-link { color: var(--charcoal); }
    .nav-link:hover { background: rgba(200,92,56,0.1); color: var(--orange); }
    .nav-link.active { color: var(--orange); }
    .nav-cta {
      background: var(--orange) !important;
      color: var(--white) !important;
      margin-left: 0.3rem;
    }
    .nav-cta:hover { background: var(--orange-dk) !important; }
    @media (max-width: 600px) {
      .nav-link.hide-mobile { display: none; }
    }

    /* ══════════════════════════════════════════
       HERO
    ══════════════════════════════════════════ */
    #hero {
      position: relative;
      min-height: 100svh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      overflow: hidden;
      background: #e8e0d8;
    }
    #hero-bg {
      position: absolute;
      inset: 0;
      background-image: url('images/hero_bg.jpg');
      background-size: cover;
      background-position: center top;
      opacity: 1;
      transform: scale(1.06);
      animation: heroKen 14s ease-out forwards;
    }
    @keyframes heroKen {
      to { transform: scale(1); }
    }
    /* Warm layered overlay — lightened */
    #hero::before {
      content: '';
      position: absolute; inset: 0; z-index: 0.5;
      background: radial-gradient(ellipse 60% 50% at 50% 45%, rgba(240,225,205,0.06) 0%, rgba(180,120,70,0.10) 100%);
    }
    #hero::after {
      content: '';
      position: absolute; inset: 0; z-index: 1;
      background: linear-gradient(
        to bottom,
        rgba(30,12,4,0.40)  0%,
        rgba(20,8,2,0.08)   28%,
        rgba(20,8,2,0.06)   55%,
        rgba(20,8,2,0.50)   100%
      );
    }
    .hero-content {
      position: relative;
      z-index: 2;
      color: var(--white);
      padding: 6rem 2rem 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .hero-eyebrow {
      font-family: var(--font-sans);
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.38em;
      text-transform: uppercase;
      color: var(--champagne-lt);
      margin-bottom: 1.4rem;
      opacity: 0;
      animation: fadeUp 0.9s var(--ease) 0.2s forwards;
      text-shadow: 0 1px 8px rgba(0,0,0,0.7);
    }
    /* ── GREAT VIBES DISPLAY NAMES — calligraphic script ── */
    .hero-name {
      font-family: 'Italianno', cursive;
      font-size: clamp(3.2rem, 9vw, 7rem);
      font-weight: 400;
      line-height: 0.95;
      letter-spacing: 0em;
      color: var(--white);
      display: block;
      text-shadow:
        0 2px 4px rgba(0,0,0,0.65),
        0 4px 16px rgba(0,0,0,0.5),
        0 10px 40px rgba(0,0,0,0.35),
        0 20px 60px rgba(0,0,0,0.2);
      opacity: 0;
    }
    .hero-name.n1 { animation: revealName 1s var(--ease) 0.38s forwards; }
    .hero-name.n2 { animation: revealName 1s var(--ease) 0.6s  forwards; }
    @keyframes revealName {
      from { opacity: 0; transform: translateY(50px); }
      to   { opacity: 1; transform: translateY(0);    }
    }
    .hero-amp {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: clamp(1.6rem, 4.5vw, 3rem);
      color: var(--orange-lt);
      display: block;
      margin: 0.5rem 0;
      opacity: 0;
      animation: fadeUp 0.8s var(--ease) 0.5s forwards;
      text-shadow: 0 2px 12px rgba(0,0,0,0.55);
    }
    .hero-surnames {
      font-family: var(--font-sans);
      font-size: clamp(0.58rem, 1.4vw, 0.72rem);
      font-weight: 600;
      letter-spacing: 0.42em;
      text-transform: uppercase;
      color: var(--champagne-lt);
      margin-top: 1rem;
      opacity: 0;
      animation: fadeUp 0.8s var(--ease) 0.75s forwards;
      text-shadow: 0 1px 8px rgba(0,0,0,0.65);
    }
    .hero-date {
      font-family: var(--font-serif);
      font-size: clamp(1rem, 2.2vw, 1.3rem);
      color: var(--orange-lt);
      margin: 1.6rem 0 0.4rem;
      font-weight: 300;
      opacity: 0;
      animation: fadeUp 0.8s var(--ease) 0.88s forwards;
      text-shadow: 0 2px 12px rgba(0,0,0,0.55);
    }
    .hero-hosts {
      font-size: 0.72rem;
      font-weight: 400;
      letter-spacing: 0.07em;
      color: rgba(255,255,255,0.9);
      margin-bottom: 2.5rem;
      opacity: 0;
      animation: fadeUp 0.8s var(--ease) 1s forwards;
      text-shadow: 0 1px 8px rgba(0,0,0,0.65);
    }

    /* ── COUNTDOWN – frosted dark glass, thin champagne rim ── */
    .countdown-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.6rem;
      opacity: 0;
      animation: fadeUp 0.8s var(--ease) 1.1s forwards;
    }
    .countdown-glass {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
    }
    .countdown-unit {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 70px;
      padding: 0.9rem 0 0.7rem;
      background: rgba(8,3,1,0.48);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border: 1px solid rgba(232,213,163,0.65);
      border-radius: 14px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.28), inset 0 1px 0 rgba(255,255,255,0.07);
    }
    .countdown-num {
      font-family: var(--font-serif);
      font-size: 2.2rem;
      font-weight: 300;
      color: var(--champagne);
      line-height: 1;
      text-shadow: 0 2px 8px rgba(0,0,0,0.4);
    }
    .countdown-label {
      font-family: var(--font-sans);
      font-size: 0.38rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(232,213,163,0.8);
      margin-top: 0.45rem;
    }
    .countdown-sep {
      font-family: var(--font-serif);
      font-size: 1.6rem;
      color: rgba(232,213,163,0.55);
      align-self: center;
      margin-bottom: 0.6rem;
      line-height: 1;
      user-select: none;
    }

    /* RSVP button — strictly below countdown */
    .btn-rsvp-hero {
      display: inline-block;
      background: var(--orange);
      border: none;
      color: var(--white);
      font-family: var(--font-sans);
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      padding: 0.9rem 2.8rem;
      border-radius: var(--radius);
      cursor: pointer;
      transition: background 0.3s ease, transform 0.2s ease, box-shadow 0.2s ease;
    }
    .btn-rsvp-hero:hover {
      background: var(--orange-dk);
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(200,92,56,0.45);
    }
    .btn-rsvp-hero:active { transform: scale(0.98); }

    .scroll-hint {
      font-size: 0.58rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-top: 2.2rem;
      animation: bounce 2.5s ease infinite;
    }

    /* ══════════════════════════════════════════
       OUR STORY — RTL INFINITE SLIDESHOW
    ══════════════════════════════════════════ */
    #couple {
      background: var(--cream);
      padding: 6rem 0 5rem;
      overflow: hidden;
    }
    .couple-header {
      text-align: center;
      padding: 0 2rem;
      max-width: 680px;
      margin: 0 auto 3.5rem;
    }
    .couple-full-names {
      font-family: var(--font-serif);
      font-size: clamp(1rem, 2.2vw, 1.3rem);
      font-style: italic;
      color: var(--brown-lt);
      margin-top: 0.6rem;
      line-height: 1.5;
    }
    .couple-tagline {
      font-family: var(--font-serif);
      font-size: 1.05rem;
      color: var(--gray);
      font-style: italic;
      max-width: 500px;
      margin: 1rem auto 0;
      line-height: 1.75;
    }

    /* ── COUPLE CROSSFADE SLIDESHOW ── */
    .couple-slideshow {
      position: relative;
      width: 100%;
      max-width: 580px;
      margin: 0 auto;
      aspect-ratio: 848 / 1264;
      border-radius: 22px;
      overflow: hidden;
      box-shadow: var(--shadow-lg);
    }
    .couple-slideshow .slide-item {
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 1.4s ease-in-out;
      pointer-events: none;
    }
    .couple-slideshow .slide-item.active {
      opacity: 1;
      pointer-events: auto;
    }
    .couple-slideshow .slide-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: contrast(1.04) saturate(1.08);
      display: block;
    }
    /* Mobile: full bleed, no mask — images fade cleanly */
    @media (max-width: 640px) {
      .couple-slideshow {
        max-width: 92%;
        border-radius: 14px;
        aspect-ratio: 848 / 1264;
        box-shadow: var(--shadow-lg);
        -webkit-mask-image: none;
        mask-image: none;
      }
    }

    /* ══════════════════════════════════════════
       LOVE STORY
    ══════════════════════════════════════════ */
    #story {
      background: linear-gradient(145deg, #3d1208 0%, #6b2810 40%, #7a3018 70%, #4a1a08 100%);
      padding: 6rem 2rem;
    }
    .story-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4.5rem;
      align-items: center;
    }
    #story .section-label { color: var(--champagne); }
    #story .section-title { color: #fdf8f4; }
    #story .section-title em { color: var(--champagne); }
    #story .divider::before, #story .divider::after { background: linear-gradient(to right, transparent, var(--champagne-dk), transparent); }
    #story .divider span { color: var(--champagne); }

    .story-img { position: relative; }
    .story-img img {
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      border-radius: 14px;
      filter: contrast(1.05) saturate(1.08);
      box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    }
    .story-img-quote {
      position: absolute;
      bottom: -1.8rem;
      right: -1.8rem;
      background: rgba(253,248,244,0.97);
      padding: 1.2rem 1.5rem;
      max-width: 260px;
      border-radius: 10px;
      box-shadow: var(--shadow-lg);
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 0.9rem;
      color: var(--brown);
      line-height: 1.55;
    }
    .timeline { margin-top: 2.5rem; position: relative; }
    .timeline::before {
      content: '';
      position: absolute;
      left: 10px; top: 4px; bottom: 0;
      width: 1px;
      background: linear-gradient(to bottom, var(--champagne-dk), transparent);
    }
    .timeline-item { display: flex; gap: 1.5rem; margin-bottom: 2.2rem; position: relative; }
    .timeline-dot {
      width: 21px; height: 21px;
      border-radius: 50%;
      border: 1.5px solid var(--champagne-dk);
      background: rgba(255,255,255,0.1);
      flex-shrink: 0;
      margin-top: 0.2rem;
      position: relative; z-index: 1;
      transition: background 0.3s ease;
    }
    .timeline-item:hover .timeline-dot { background: rgba(200,92,56,0.35); }
    .timeline-date {
      font-family: var(--font-sans);
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      color: var(--champagne-dk);
      text-transform: uppercase;
      margin-bottom: 0.2rem;
    }
    .timeline-title {
      font-family: var(--font-serif);
      font-size: 1.1rem;
      font-weight: 500;
      color: #fdf8f4;
    }
    .timeline-desc { font-size: 0.82rem; color: rgba(253,232,200,0.72); margin-top: 0.2rem; }
    .story-closing {
      margin-top: 2.5rem;
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 1.05rem;
      color: rgba(253,232,200,0.85);
      line-height: 1.75;
    }
    @media (max-width: 768px) {
      .story-inner { grid-template-columns: 1fr; gap: 3rem; }
      .story-img-quote { right: 0; max-width: 220px; }
    }

    /* ══════════════════════════════════════════
       SCHEDULE
    ══════════════════════════════════════════ */
    #schedule {
      background: linear-gradient(160deg, var(--champagne-lt) 0%, #fdf0e0 100%);
      padding: 6rem 2rem;
    }
    .schedule-inner { max-width: 900px; margin: 0 auto; text-align: center; }
    .schedule-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-top: 3rem;
      text-align: left;
    }
    .event-card {
      background: var(--white);
      border: 1px solid var(--light-gray);
      padding: 2rem;
      border-radius: 18px;
      box-shadow: var(--shadow);
      position: relative;
      transition: box-shadow 0.3s ease, transform 0.3s var(--ease);
    }
    .event-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-4px); }
    .event-num {
      position: absolute; top: 1.5rem; right: 1.5rem;
      font-family: var(--font-serif);
      font-size: 2.8rem;
      font-weight: 300;
      color: var(--light-gray);
      line-height: 1;
    }
    .event-category {
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 0.4rem;
    }
    .event-title {
      font-family: var(--font-serif);
      font-size: 1.35rem;
      font-weight: 400;
      color: var(--charcoal);
      margin-bottom: 1.2rem;
    }
    .event-details { list-style: none; }
    .event-details li {
      font-size: 0.78rem;
      color: var(--gray);
      margin-bottom: 0.5rem;
      display: flex;
      align-items: flex-start;
      gap: 0.5rem;
      line-height: 1.5;
    }
    .btn-cal {
      display: inline-block;
      margin-top: 1.2rem;
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--white);
      background: var(--orange);
      border-radius: var(--radius);
      padding: 0.45rem 1.1rem;
      transition: background 0.2s;
    }
    .btn-cal:hover { background: var(--orange-dk); }
    @media (max-width: 640px) { .schedule-grid { grid-template-columns: 1fr; } }

    /* ══════════════════════════════════════════
       LOCATIONS
    ══════════════════════════════════════════ */
    #locations { background: var(--warm-white); padding: 6rem 2rem; text-align: center; }
    .locations-inner { max-width: 900px; margin: 0 auto; }
    .locations-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-top: 3rem;
      text-align: left;
    }
    .location-card {
      background: var(--white);
      padding: 2rem;
      border: 1px solid var(--light-gray);
      border-radius: 18px;
      box-shadow: var(--shadow);
      transition: transform 0.3s var(--ease), box-shadow 0.3s ease;
    }
    .location-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
    .location-icon { font-size: 1.5rem; margin-bottom: 0.8rem; }
    .location-label {
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 0.35rem;
    }
    .location-name {
      font-family: var(--font-serif);
      font-size: 1.2rem;
      font-weight: 500;
      color: var(--charcoal);
      margin-bottom: 0.4rem;
    }
    .location-address { font-size: 0.8rem; color: var(--gray); margin-bottom: 1rem; line-height: 1.6; }
    .location-link {
      display: inline-block;
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--white);
      background: var(--orange);
      border-radius: var(--radius);
      padding: 0.45rem 1.1rem;
      transition: background 0.2s;
    }
    .location-link:hover { background: var(--orange-dk); }
    @media (max-width: 640px) { .locations-grid { grid-template-columns: 1fr; } }

    /* ══════════════════════════════════════════
       DRESS CODE — UPGRADED
    ══════════════════════════════════════════ */
    #dresscode {
      background: linear-gradient(155deg, #fdf0e0 0%, var(--champagne-lt) 100%);
      padding: 6rem 2rem;
      text-align: center;
    }
    .dresscode-inner { max-width: 820px; margin: 0 auto; }
    .dresscode-note {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 1.1rem;
      color: var(--gray);
      max-width: 560px;
      margin: 0.5rem auto 3rem;
      line-height: 1.75;
    }
    .dresscode-swatches {
      display: flex;
      justify-content: center;
      gap: 2.5rem;
      flex-wrap: wrap;
      margin-bottom: 2.5rem;
    }
    .color-swatch { display: flex; flex-direction: column; align-items: center; gap: 0.8rem; }
    .swatch-circle {
      width: 88px;
      height: 88px;
      border-radius: 50%;
      border: 4px solid rgba(255,255,255,0.92);
      box-shadow: 0 8px 28px rgba(0,0,0,0.14), 0 0 0 1px rgba(0,0,0,0.06);
      transition: transform 0.35s var(--ease), box-shadow 0.35s ease;
      cursor: default;
    }
    .swatch-circle:hover { transform: scale(1.1) translateY(-5px); box-shadow: 0 14px 36px rgba(0,0,0,0.2); }
    .swatch-name {
      font-family: var(--font-serif);
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--charcoal);
    }
    .swatch-hex {
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gray);
    }
    .dresscode-events {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
      margin-top: 1rem;
    }
    .dresscode-tag {
      background: var(--white);
      border: 1px solid var(--light-gray);
      border-radius: 100px;
      padding: 0.55rem 1.3rem;
      font-size: 0.68rem;
      font-weight: 400;
      color: var(--charcoal);
      box-shadow: var(--shadow);
      line-height: 1.5;
    }
    .dresscode-tag strong { color: var(--orange); font-weight: 600; }

    /* ══════════════════════════════════════════
       MUSIC — ANIMATED WAVE
    ══════════════════════════════════════════ */
    #music { background: var(--cream); padding: 6rem 2rem; text-align: center; }
    .music-inner { max-width: 560px; margin: 0 auto; }
    .music-player {
      background: var(--white);
      border: 1px solid var(--light-gray);
      box-shadow: var(--shadow-lg);
      padding: 2.8rem 2.2rem 2.2rem;
      margin-top: 3rem;
      border-radius: 22px;
    }
    .music-title {
      font-family: var(--font-display);
      font-size: 2rem;
      font-weight: 800;
      color: var(--charcoal);
      margin-bottom: 0.15rem;
    }
    .music-artist {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gray);
      margin-bottom: 2rem;
    }

    /* Wave bars */
    .wave-visualizer {
      display: flex;
      align-items: flex-end;
      justify-content: center;
      gap: 3px;
      height: 52px;
      margin-bottom: 1.6rem;
    }
    .wave-bar {
      width: 3px;
      border-radius: 3px;
      background: linear-gradient(to top, var(--orange-dk), var(--orange-lt));
      transform-origin: bottom;
      animation: wave-anim 1.3s ease-in-out infinite alternate;
      animation-play-state: paused;
    }
    .wave-visualizer.playing .wave-bar { animation-play-state: running; }

    .wave-bar:nth-child(1)  { height: 14px; animation-delay: 0.00s; }
    .wave-bar:nth-child(2)  { height: 24px; animation-delay: 0.10s; }
    .wave-bar:nth-child(3)  { height: 36px; animation-delay: 0.05s; }
    .wave-bar:nth-child(4)  { height: 46px; animation-delay: 0.20s; }
    .wave-bar:nth-child(5)  { height: 30px; animation-delay: 0.15s; }
    .wave-bar:nth-child(6)  { height: 50px; animation-delay: 0.08s; }
    .wave-bar:nth-child(7)  { height: 38px; animation-delay: 0.22s; }
    .wave-bar:nth-child(8)  { height: 44px; animation-delay: 0.12s; }
    .wave-bar:nth-child(9)  { height: 26px; animation-delay: 0.18s; }
    .wave-bar:nth-child(10) { height: 52px; animation-delay: 0.06s; }
    .wave-bar:nth-child(11) { height: 42px; animation-delay: 0.25s; }
    .wave-bar:nth-child(12) { height: 34px; animation-delay: 0.09s; }
    .wave-bar:nth-child(13) { height: 46px; animation-delay: 0.17s; }
    .wave-bar:nth-child(14) { height: 22px; animation-delay: 0.03s; }
    .wave-bar:nth-child(15) { height: 38px; animation-delay: 0.21s; }
    .wave-bar:nth-child(16) { height: 50px; animation-delay: 0.13s; }
    .wave-bar:nth-child(17) { height: 28px; animation-delay: 0.07s; }
    .wave-bar:nth-child(18) { height: 44px; animation-delay: 0.26s; }
    .wave-bar:nth-child(19) { height: 18px; animation-delay: 0.04s; }
    .wave-bar:nth-child(20) { height: 12px; animation-delay: 0.14s; }

    @keyframes wave-anim {
      0%   { transform: scaleY(0.18); opacity: 0.5; }
      100% { transform: scaleY(1);    opacity: 1;   }
    }

    .music-progress {
      width: 100%;
      height: 3px;
      background: var(--light-gray);
      border-radius: 2px;
      margin-bottom: 1.2rem;
      cursor: pointer;
      overflow: hidden;
    }
    .music-progress-bar { height: 100%; background: var(--orange); width: 0%; transition: width 0.1s linear; }
    .music-controls {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.2rem;
      margin-bottom: 1.4rem;
    }
    .btn-play {
      width: 58px; height: 58px;
      border-radius: 50%;
      border: none;
      background: var(--orange);
      color: var(--white);
      font-size: 1.1rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.25s ease, transform 0.2s var(--ease), box-shadow 0.2s ease;
    }
    .btn-play:hover {
      background: var(--orange-dk);
      transform: scale(1.1);
      box-shadow: 0 8px 24px rgba(200,92,56,0.38);
    }
    .music-quote {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 0.98rem;
      color: var(--brown-lt);
      margin-top: 0.5rem;
    }
    audio { display: none; }

    /* ══════════════════════════════════════════
       GALLERY — ON PAGE
    ══════════════════════════════════════════ */
    #gallery {
      background: linear-gradient(155deg, var(--champagne-lt) 0%, #fdf0e0 100%);
      padding: 6rem 2rem;
      text-align: center;
    }
    .gallery-inner { max-width: 1100px; margin: 0 auto; }
    .gallery-description {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 1.05rem;
      color: var(--gray);
      max-width: 500px;
      margin: 0.5rem auto 3rem;
      line-height: 1.75;
    }
    .gallery-grid {
      columns: 3 180px;
      column-gap: 1rem;
    }
    .gallery-item {
      break-inside: avoid;
      margin-bottom: 1rem;
      border-radius: 14px;
      overflow: hidden;
      box-shadow: var(--shadow);
      position: relative;
      cursor: zoom-in;
    }
    .gallery-item img {
      width: 100%;
      display: block;
      filter: contrast(1.04) saturate(1.1);
      transition: transform 0.55s var(--ease);
    }
    .gallery-item:hover img { transform: scale(1.06); }
    .gallery-overlay {
      position: absolute;
      inset: 0;
      background: rgba(60,25,10,0);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.3s ease;
    }
    .gallery-overlay span {
      color: white;
      font-size: 1.6rem;
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .gallery-item:hover .gallery-overlay { background: rgba(60,25,10,0.28); }
    .gallery-item:hover .gallery-overlay span { opacity: 1; }

    /* Lightbox */
    .lightbox {
      position: fixed;
      inset: 0;
      background: rgba(15,6,2,0.92);
      z-index: 2000;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }
    .lightbox.open { display: flex; }
    .lightbox-img {
      max-width: 90vw;
      max-height: 88vh;
      border-radius: 14px;
      object-fit: contain;
      box-shadow: 0 24px 80px rgba(0,0,0,0.55);
      animation: lbIn 0.35s var(--ease) both;
    }
    @keyframes lbIn {
      from { opacity: 0; transform: scale(0.93); }
      to   { opacity: 1; transform: scale(1);    }
    }
    .lightbox-close {
      position: absolute;
      top: 1.5rem; right: 2rem;
      color: rgba(255,255,255,0.65);
      font-size: 2rem;
      cursor: pointer;
      background: none; border: none;
      transition: color 0.2s, transform 0.2s;
    }
    .lightbox-close:hover { color: white; transform: rotate(90deg); }

    /* ══════════════════════════════════════════
       CONTACTS
    ══════════════════════════════════════════ */
    #contacts { background: var(--warm-white); padding: 6rem 2rem; text-align: center; }
    .contacts-inner { max-width: 700px; margin: 0 auto; }
    .contacts-subtitle {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 1.05rem;
      color: var(--gray);
      max-width: 460px;
      margin: 0 auto 3rem;
      line-height: 1.7;
    }
    .contacts-grid {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .contact-card {
      background: var(--white);
      border: 1px solid var(--light-gray);
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 2rem 1.8rem;
      min-width: 168px;
      flex: 1 1 150px;
      max-width: 210px;
      transition: transform 0.3s var(--ease), box-shadow 0.3s ease;
    }
    .contact-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); }
    .contact-avatar {
      width: 50px; height: 50px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--champagne-lt), var(--light-gray));
      color: var(--orange-dk);
      font-family: var(--font-display);
      font-size: 1.3rem;
      font-weight: 800;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1rem;
      border: 2px solid var(--champagne);
    }
    .contact-name {
      font-family: var(--font-serif);
      font-size: 1rem;
      font-weight: 500;
      color: var(--charcoal);
      margin-bottom: 0.25rem;
    }
    .contact-role {
      font-size: 0.56rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 0.7rem;
    }
    .contact-phone {
      font-size: 0.84rem;
      color: var(--brown-lt);
      font-weight: 500;
      display: block;
      transition: color 0.2s;
    }
    .contact-phone:hover { color: var(--orange); }

    /* ══════════════════════════════════════════
       FOOTER
    ══════════════════════════════════════════ */
    footer {
      background: #1E0E06;
      color: rgba(255,255,255,0.55);
      text-align: center;
      padding: 5rem 2rem 3.5rem;
    }
    .footer-names {
      font-family: var(--font-display);
      font-size: clamp(2.2rem, 6vw, 4rem);
      font-weight: 300;
      color: var(--white);
      letter-spacing: 0em;
      margin-bottom: 0.2rem;
    }
    .footer-names em {
      font-style: italic;
      color: var(--champagne-dk);
      font-size: 0.65em;
      vertical-align: middle;
      margin: 0 0.3rem;
    }
    .footer-date {
      font-family: var(--font-serif);
      font-size: 0.9rem;
      font-style: italic;
      color: var(--champagne);
      margin-bottom: 2.5rem;
    }
    .footer-divider {
      display: flex;
      align-items: center;
      gap: 1rem;
      max-width: 200px;
      margin: 0 auto 2rem;
      opacity: 0.2;
    }
    .footer-divider::before, .footer-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--champagne);
    }
    .footer-divider span { color: var(--champagne); font-size: 0.7rem; }
    .footer-made { font-size: 0.62rem; letter-spacing: 0.08em; }
    .footer-made a {
      color: var(--champagne-dk);
      text-decoration: underline;
      text-underline-offset: 3px;
      transition: color 0.2s;
    }
    .footer-made a:hover { color: var(--orange-lt); }

    /* ══════════════════════════════════════════
       MUSIC FAB
    ══════════════════════════════════════════ */
    #music-fab {
      position: fixed;
      bottom: 1.5rem; right: 1.5rem;
      z-index: 500;
      width: 50px; height: 50px;
      border-radius: 50%;
      background: var(--orange);
      color: var(--white);
      border: none;
      cursor: pointer;
      box-shadow: 0 4px 20px rgba(200,92,56,0.42);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      transition: background 0.25s, transform 0.25s var(--ease);
    }
    #music-fab:hover { background: var(--orange-dk); transform: scale(1.1); }
    #music-fab.playing { background: var(--orange-dk); }

    .fab-wave-bars {
      display: none;
      align-items: flex-end;
      gap: 2px;
      height: 18px;
    }
    #music-fab.playing .fab-wave-bars { display: flex; }
    #music-fab.playing .fab-icon { display: none; }
    .fab-wave-bar {
      width: 2.5px;
      background: white;
      border-radius: 2px;
      transform-origin: bottom;
      animation: wave-anim 1s ease-in-out infinite alternate;
    }
    .fab-wave-bar:nth-child(1) { height: 8px;  animation-delay: 0.0s; }
    .fab-wave-bar:nth-child(2) { height: 14px; animation-delay: 0.15s; }
    .fab-wave-bar:nth-child(3) { height: 10px; animation-delay: 0.08s; }
    .fab-wave-bar:nth-child(4) { height: 16px; animation-delay: 0.22s; }

    /* ══════════════════════════════════════════
       ANIMATIONS & SCROLL REVEALS
    ══════════════════════════════════════════ */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(22px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50%       { transform: translateY(-7px); }
    }

    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.75s var(--ease), transform 0.75s var(--ease);
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* Stagger for grid children */
    .stagger-reveal > * {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.7s var(--ease), transform 0.7s var(--ease);
    }
    .stagger-reveal.visible > *:nth-child(1) { opacity: 1; transform: none; transition-delay: 0s; }
    .stagger-reveal.visible > *:nth-child(2) { opacity: 1; transform: none; transition-delay: 0.1s; }
    .stagger-reveal.visible > *:nth-child(3) { opacity: 1; transform: none; transition-delay: 0.2s; }
    .stagger-reveal.visible > *:nth-child(4) { opacity: 1; transform: none; transition-delay: 0.3s; }
    .stagger-reveal.visible > *:nth-child(5) { opacity: 1; transform: none; transition-delay: 0.4s; }

    /* ══════════════════════════════════════════
       RESPONSIVE
    ══════════════════════════════════════════ */
    @media (max-width: 480px) {
      .countdown-unit { width: 58px; border-radius: 10px; }
      .countdown-num { font-size: 1.8rem; }
      .countdown-sep { font-size: 1.3rem; }
      .slide-img { width: 155px; }
    }

    /* ══════════════════════════════════════════
       RSVP SECTION
    ══════════════════════════════════════════ */
    #rsvp {
      background: linear-gradient(160deg, #fdf0e0 0%, var(--champagne-lt) 100%);
      padding: 6rem 2rem;
      text-align: center;
    }
    .rsvp-inner { max-width: 640px; margin: 0 auto; }
    .rsvp-body-text {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 1.05rem;
      color: var(--gray);
      max-width: 460px;
      margin: 0.5rem auto 2.5rem;
      line-height: 1.75;
    }
    .btn-rsvp-open {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: var(--orange);
      color: var(--white);
      font-family: var(--font-sans);
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      padding: 1rem 2.6rem;
      border-radius: var(--radius);
      border: none;
      cursor: pointer;
      transition: background 0.3s ease, transform 0.2s ease, box-shadow 0.2s ease;
      box-shadow: 0 4px 20px rgba(200,92,56,0.3);
    }
    .btn-rsvp-open:hover {
      background: var(--orange-dk);
      transform: translateY(-2px);
      box-shadow: 0 10px 32px rgba(200,92,56,0.45);
    }
    .btn-rsvp-open:active { transform: scale(0.98); }
    .rsvp-deadline {
      font-size: 0.64rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      color: var(--gray);
      margin-top: 1.2rem;
      text-transform: uppercase;
    }

    /* ══════════════════════════════════════════
       RSVP MODAL
    ══════════════════════════════════════════ */
    .rsvp-overlay {
      position: fixed;
      inset: 0;
      background: rgba(15,6,2,0.72);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      z-index: 1500;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.35s var(--ease);
    }
    .rsvp-overlay.open {
      opacity: 1;
      pointer-events: all;
    }
    .rsvp-modal {
      background: var(--warm-white);
      border-radius: 24px;
      width: 100%;
      max-width: 520px;
      max-height: 90vh;
      overflow-y: auto;
      box-shadow: 0 30px 80px rgba(0,0,0,0.35);
      padding: 0;
      transform: translateY(32px) scale(0.97);
      transition: transform 0.4s var(--ease);
      scrollbar-width: thin;
      scrollbar-color: var(--champagne-dk) transparent;
    }
    .rsvp-overlay.open .rsvp-modal {
      transform: translateY(0) scale(1);
    }
    .rsvp-modal-header {
      background: linear-gradient(145deg, var(--brown-dk) 0%, #6b2810 100%);
      padding: 2.2rem 2rem 1.8rem;
      text-align: center;
      position: relative;
      border-radius: 24px 24px 0 0;
    }
    .rsvp-modal-eyebrow {
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--champagne);
      margin-bottom: 0.5rem;
    }
    .rsvp-modal-names {
      font-family: var(--font-serif);
      font-size: 1.5rem;
      font-weight: 400;
      color: var(--white);
      font-style: italic;
    }
    .rsvp-modal-names em {
      color: var(--champagne);
      font-style: normal;
      font-size: 0.9em;
      margin: 0 0.3rem;
    }
    .rsvp-modal-date {
      font-size: 0.65rem;
      color: rgba(232,213,163,0.75);
      margin-top: 0.35rem;
      letter-spacing: 0.1em;
    }
    .rsvp-close {
      position: absolute;
      top: 1rem; right: 1.2rem;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.2);
      color: rgba(255,255,255,0.7);
      width: 32px; height: 32px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 0.9rem;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s, color 0.2s;
    }
    .rsvp-close:hover { background: rgba(255,255,255,0.22); color: white; }

    .rsvp-form-body { padding: 2rem; }

    .rsvp-field { margin-bottom: 1.4rem; }
    .rsvp-label {
      display: block;
      font-family: var(--font-sans);
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--brown-lt);
      margin-bottom: 0.5rem;
    }
    .rsvp-label .req { color: var(--orange); margin-left: 2px; }
    .rsvp-input, .rsvp-textarea, .rsvp-select {
      width: 100%;
      padding: 0.78rem 1rem;
      border: 1.5px solid var(--light-gray);
      border-radius: 12px;
      font-family: var(--font-sans);
      font-size: 0.88rem;
      color: var(--charcoal);
      background: var(--white);
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
      outline: none;
      appearance: none;
    }
    .rsvp-input:focus, .rsvp-textarea:focus, .rsvp-select:focus {
      border-color: var(--orange);
      box-shadow: 0 0 0 3px rgba(200,92,56,0.12);
    }
    .rsvp-textarea { resize: vertical; min-height: 80px; }

    /* Radio / checkbox groups */
    .rsvp-options { display: flex; flex-direction: column; gap: 0.55rem; }
    .rsvp-option {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.7rem 1rem;
      border: 1.5px solid var(--light-gray);
      border-radius: 10px;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
      font-size: 0.85rem;
      color: var(--charcoal);
      user-select: none;
    }
    .rsvp-option:hover { border-color: var(--champagne-dk); background: #fdf8f0; }
    .rsvp-option input { accent-color: var(--orange); width: 16px; height: 16px; flex-shrink: 0; }
    .rsvp-option.checked { border-color: var(--orange); background: rgba(200,92,56,0.05); }

    .rsvp-options.inline {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .rsvp-options.inline .rsvp-option {
      flex: 1 1 auto;
      min-width: 100px;
      justify-content: center;
    }

    .btn-rsvp-submit {
      width: 100%;
      padding: 1rem;
      background: var(--orange);
      color: var(--white);
      border: none;
      border-radius: 100px;
      font-family: var(--font-sans);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      cursor: pointer;
      margin-top: 0.8rem;
      transition: background 0.3s, transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 18px rgba(200,92,56,0.28);
    }
    .btn-rsvp-submit:hover {
      background: var(--orange-dk);
      transform: translateY(-1px);
      box-shadow: 0 8px 26px rgba(200,92,56,0.38);
    }
    .btn-rsvp-submit:active { transform: scale(0.98); }
    .btn-rsvp-submit:disabled {
      opacity: 0.7;
      cursor: not-allowed;
      transform: none;
    }

    /* Thank you state */
    .rsvp-thankyou {
      display: none;
      text-align: center;
      padding: 3rem 2rem 3.5rem;
    }
    .rsvp-thankyou.show { display: block; }
    .rsvp-form-state.hide { display: none; }
